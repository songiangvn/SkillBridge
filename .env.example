EXPO_PUBLIC_APPWRITE_ENDPOINT=http://localhost/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=
EXPO_PUBLIC_APPWRITE_DATABASE_ID=skillbridge
EXPO_PUBLIC_APPWRITE_PROFILES_COLLECTION_ID=profiles
EXPO_PUBLIC_APPWRITE_BRIDGE_REQUESTS_COLLECTION_ID=bridgeRequests
EXPO_PUBLIC_APPWRITE_SKIPPED_PROFILES_COLLECTION_ID=skippedProfiles
EXPO_PUBLIC_APPWRITE_TUTOR_SHORTLIST_COLLECTION_ID=tutorShortlist
EXPO_PUBLIC_APPWRITE_QUESTIONS_COLLECTION_ID=questions
EXPO_PUBLIC_APPWRITE_ANSWERS_COLLECTION_ID=answers
EXPO_PUBLIC_APPWRITE_RESOURCES_COLLECTION_ID=resources
EXPO_PUBLIC_APPWRITE_SAVED_RESOURCES_COLLECTION_ID=savedResources
EXPO_PUBLIC_APPWRITE_MATCHES_COLLECTION_ID=matches
EXPO_PUBLIC_APPWRITE_THREADS_COLLECTION_ID=threads
EXPO_PUBLIC_APPWRITE_MESSAGES_COLLECTION_ID=messages

# Temporary server-side setup key only. Never prefix this with EXPO_PUBLIC_.
# Delete/revoke the key in Appwrite after running `npm run setup:appwrite`.
APPWRITE_API_KEY=

# Optional demo seeding password used by `npm run seed:demo`.
# All generated demo accounts will use this password.
APPWRITE_DEMO_PASSWORD=SkillBridge123!
